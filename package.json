{
  "name": "gold-os",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "echo 'Run npm run dev in server/ and client/ in two terminals.'",
    "typecheck": "npm run typecheck -w shared && npm run typecheck -w server && npm run typecheck -w client",
    "lint": "npm run lint -w server && npm run lint -w client",
    "test": "npm run test -w server && npm run test -w client",
    "test:e2e": "playwright test",
    "test:tracking": "tsx scripts/e2e-order-tracking.ts",
    "test:load": "tsx scripts/load-orders.ts",
    "test:stress": "STRESS=1 tsx scripts/load-orders.ts",
    "test:isolation": "tsx scripts/cross-tenant-isolation.ts",
    "cleanup:load-orders": "tsx scripts/cleanup-load-test-orders.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,html}\""
  },
  "devDependencies": {
    "@playwright/test": "1.45.0",
    "prettier": "3.3.2",
    "typescript": "5.4.5"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  }
}
