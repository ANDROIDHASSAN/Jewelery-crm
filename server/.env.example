# All keys from specs/gotchas.md. Server crashes loud at boot if any are missing.

# Core
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://goldos:goldos@localhost:5432/goldos
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=replace-me-min-32-chars-access-secret-please
JWT_REFRESH_SECRET=replace-me-min-32-chars-refresh-secret-please

# WhatsApp (Meta Cloud API)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_RECEIPT=receipt_v1
WHATSAPP_TEMPLATE_OTP=otp_v1
WHATSAPP_TEMPLATE_ABANDONED_CART=abandoned_cart_v1

# Twilio SMS fallback
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Gold rate
MCX_API_KEY=

# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Shipping
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# S3 / MinIO
S3_BUCKET=goldos-dev
S3_ACCESS_KEY=goldos
S3_SECRET_KEY=goldos-dev-secret
S3_ENDPOINT=http://localhost:9000

# Sentry
SENTRY_DSN=
