// Gold OS — full schema per specs/data-model.md.
// All money in paise (Int). All weight in mg (Int). All rates in bps (Int).
// All purity as carat × 100. All timestamps UTC. Soft-delete via isActive/status.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Direct (non-pooled) URL used by `prisma migrate deploy` and other DDL ops.
  // Falls back to DATABASE_URL when unset (local dev). On Neon, this should be
  // the same host as DATABASE_URL with `-pooler` stripped.
  directUrl = env("DIRECT_DATABASE_URL")
}

// --------------------------------------------------------------------------
// Tenancy
// --------------------------------------------------------------------------

enum Plan {
  STARTER
  GROWTH
  SCALE
}

model Tenant {
  id            String   @id @default(cuid())
  businessName  String
  gstNumber     String?
  phone         String
  ownerEmail    String   @unique
  plan          Plan     @default(STARTER)
  brandPrimary  String   @default("#C99B2A")
  logoUrl       String?
  createdAt     DateTime @default(now())

  shops         Shop[]
  users         User[]
  roles         Role[]
  categories    Category[]
  items         Item[]
  itemMovements ItemMovement[]
  vendors       Vendor[]
  purchaseOrders PurchaseOrder[]
  customers     Customer[]
  bills         Bill[]
  expenses      Expense[]
  goldLoans     GoldLoan[]
  payrolls      Payroll[]
  leads         Lead[]
  whatsappMessages WhatsAppMessage[]
  products      Product[]
  orders        Order[]
  cartItems     CartItem[]
  wishlistItems WishlistItem[]
  auditLogs     AuditLog[]
  storefrontContent StorefrontContent?
  registerSessions  RegisterSession[]
  parkedBills       ParkedBill[]
  estimates         Estimate[]
  repairs           Repair[]
  advances          Advance[]
  cashMovements     CashMovement[]
  vendorPayments    VendorPayment[]
  bankAccounts      BankAccount[]
  bankTransactions  BankTransaction[]
  reconciliations   Reconciliation[]
  invitations       UserInvitation[]

  @@index([ownerEmail])
}

model Shop {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  address      String
  gstStateCode String
  phone        String
  isActive     Boolean  @default(true)

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users        User[]
  items        Item[]
  bills        Bill[]
  expenses     Expense[]
  registerSessions RegisterSession[]
  parkedBills      ParkedBill[]
  estimates        Estimate[]
  repairs          Repair[]
  advances         Advance[]
  cashMovements    CashMovement[]
  invitations      UserInvitation[]

  @@index([tenantId])
  @@index([tenantId, isActive])
}

// --------------------------------------------------------------------------
// RBAC: Role, Permission, RolePermission, UserPermission
// --------------------------------------------------------------------------

// Roles live per-tenant. The 4 built-in role slugs (SUPER_ADMIN, ACCOUNTANT,
// EMPLOYEE, POS_USER) are seeded for every tenant with `isSystem=true`. A
// super-admin can create custom roles in the same table with `isSystem=false`,
// using any free-form slug, and edit the permission set on every role
// including the built-ins.
//
// Per-tenant copies of built-ins let tenants rename "Accountant" → "Munim"
// or remove a perm from "Employee" without affecting other tenants.
model Role {
  id          String   @id @default(cuid())
  tenantId    String
  slug        String   // "SUPER_ADMIN", "ACCOUNTANT", custom "BRIDAL_DESK", etc.
  name        String   // display label
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]
  permissions RolePermission[]
  invitations UserInvitation[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

// Permission catalog. Global, system-managed (seeded on app boot). Users
// cannot create new permissions — only super admins assigning them.
model Permission {
  id          String   @id @default(cuid())
  key         String   @unique   // "inventory.read"
  module      String              // "inventory"
  action      String              // "read"
  description String

  roles       RolePermission[]
  userGrants  UserPermission[]

  @@index([module])
}

// Many-to-many: which permissions a role carries.
model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

// Per-user override on top of role grants. `granted=true` = explicit grant
// beyond role; `granted=false` = explicit deny (overrides role grant).
// Effective permissions = (role grants ∪ user grants) \ user denies.
model UserPermission {
  userId       String
  permissionId String
  granted      Boolean
  reason       String?  // free-form audit note
  createdAt    DateTime @default(now())

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@index([permissionId])
}

model User {
  id                   String    @id @default(cuid())
  tenantId             String
  shopId               String?
  roleId               String
  name                 String
  email                String
  phone                String?
  passwordHash         String?
  mustChangePassword   Boolean   @default(true)
  passwordChangedAt    DateTime?
  totpSecret           String?
  totpEnabled          Boolean   @default(false)
  totpBackupCodes      String[]  @default([]) // bcrypt-hashed one-time codes
  failedLoginAttempts  Int       @default(0)
  lockedUntil          DateTime?
  lastLoginAt          DateTime?
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  createdByUserId      String?

  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shop                 Shop?     @relation(fields: [shopId], references: [id])
  role                 Role      @relation(fields: [roleId], references: [id])
  permissionOverrides  UserPermission[]
  registerSessions     RegisterSession[]
  parkedBills          ParkedBill[]
  estimates            Estimate[]
  repairsIntake        Repair[]   @relation("RepairIntakeBy")
  advancesCreated      Advance[]
  cashMovements        CashMovement[]

  @@unique([tenantId, email])
  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([tenantId, roleId])
  @@index([tenantId, shopId])
}

// --------------------------------------------------------------------------
// Invitations — admin invites staff via a one-time link instead of sharing
// a temporary password manually. The token is SHA-256-hashed at rest; the
// plaintext is shown to the admin once (and only once) at create-time and
// embedded in the shareable link. Tokens expire after 7 days. Accepting an
// invitation creates the User row (with the password the invitee chose),
// stamps `acceptedAt`, and the token can never be reused.
// --------------------------------------------------------------------------

model UserInvitation {
  id            String    @id @default(cuid())
  tenantId      String
  email         String
  name          String
  roleId        String
  shopId        String?
  tokenHash     String    @unique
  expiresAt     DateTime
  invitedByUserId String?
  acceptedAt    DateTime?
  acceptedUserId  String?
  revokedAt     DateTime?
  createdAt     DateTime  @default(now())

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role          Role      @relation(fields: [roleId], references: [id])
  shop          Shop?     @relation(fields: [shopId], references: [id])

  @@index([tenantId])
  @@index([tenantId, email])
  @@index([expiresAt])
}

// --------------------------------------------------------------------------
// Auth events — security-relevant signal so a merchant can see "did anyone
// try to break in?". Append-only, never updated. Captured by middleware and
// the auth service. Includes login attempts (success + failure + lockout),
// password changes, 2FA toggles, invitation accepts, role assignments.
// --------------------------------------------------------------------------

enum AuthEventType {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGIN_LOCKED
  LOGOUT
  PASSWORD_CHANGE
  PASSWORD_RESET
  TOTP_ENABLED
  TOTP_DISABLED
  INVITATION_SENT
  INVITATION_ACCEPTED
  INVITATION_REVOKED
  ROLE_CHANGED
  USER_DEACTIVATED
}

model AuthEvent {
  id          String        @id @default(cuid())
  tenantId    String?
  userId      String?
  type        AuthEventType
  email       String?
  ipAddress   String?
  userAgent   String?
  meta        Json?
  createdAt   DateTime      @default(now())

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
}

// --------------------------------------------------------------------------
// Inventory
// --------------------------------------------------------------------------

enum MetalType {
  GOLD
  SILVER
  DIAMOND
  PLATINUM
  OTHER
}

enum HallmarkStatus {
  PENDING
  SUBMITTED
  CERTIFIED
  EXEMPT
}

enum ItemStatus {
  IN_STOCK
  IN_TRANSIT
  SOLD
  MELTED
}

enum ItemMovementType {
  PURCHASE
  TRANSFER
  SALE
  RETURN
  WASTAGE
  ADJUSTMENT
}

enum PurchaseOrderStatus {
  DRAFT
  PLACED
  PARTIAL
  RECEIVED
  CANCELLED
}

model Category {
  id                      String     @id @default(cuid())
  tenantId                String
  name                    String
  parentId                String?
  metalType               MetalType
  defaultMakingChargeBps  Int

  tenant                  Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent                  Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children                Category[] @relation("CategoryTree")
  items                   Item[]
  products                Product[]

  @@index([tenantId])
}

model Item {
  id                String         @id @default(cuid())
  tenantId          String
  shopId            String
  categoryId        String
  sku               String
  barcodeData       String
  // Item display name shown in POS catalog & on the printed receipt. Falls
  // back to `sku` in legacy rows that pre-date this column.
  name              String?
  // Cloudinary-hosted product images. First entry is the hero shown in the
  // catalog grid + bill thumbnails; the rest power a future image carousel.
  images            String[]       @default([])
  weightMg          Int
  purityCaratX100   Int
  stoneWeightMg     Int?
  hallmarkStatus    HallmarkStatus @default(PENDING)
  hallmarkRef       String?
  costPricePaise    Int
  makingChargeBps   Int?
  status            ItemStatus     @default(IN_STOCK)
  createdAt         DateTime       @default(now())

  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shop              Shop           @relation(fields: [shopId], references: [id])
  category          Category       @relation(fields: [categoryId], references: [id])
  movements         ItemMovement[]
  billLines         BillLine[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([tenantId, shopId])
  @@index([tenantId, categoryId])
  @@index([barcodeData])
}

model ItemMovement {
  id                 String           @id @default(cuid())
  tenantId           String
  itemId             String
  fromShopId         String?
  toShopId           String?
  type               ItemMovementType
  qty                Int              @default(1)
  reason             String?
  performedByUserId  String?
  createdAt          DateTime         @default(now())

  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  item               Item             @relation(fields: [itemId], references: [id])

  @@index([tenantId])
  @@index([tenantId, itemId])
  @@index([tenantId, createdAt])
}

model Vendor {
  id                 String  @id @default(cuid())
  tenantId           String
  name               String
  gstNumber          String?
  phone              String
  address            String
  outstandingPaise   Int     @default(0)

  tenant             Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrders     PurchaseOrder[]
  payments           VendorPayment[]
  expenses           Expense[]

  @@index([tenantId])
}

// VendorPayment records cash going OUT to a vendor — used to drive the vendor
// ledger (purchases - payments = outstanding). Separate from Expense so the
// jewellery owner sees "paid Rajesh ₹2L" distinctly from "paid rent ₹40k".
model VendorPayment {
  id            String   @id @default(cuid())
  tenantId      String
  vendorId      String
  shopId        String?
  amountPaise   Int
  paymentMode   PaymentMode
  referenceId   String?
  paidAt        DateTime
  notes         String?
  bankAccountId String?
  createdAt     DateTime @default(now())

  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vendor        Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id])

  @@index([tenantId, vendorId, paidAt])
  @@index([tenantId, paidAt])
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  tenantId     String
  vendorId     String
  status       PurchaseOrderStatus @default(DRAFT)
  totalPaise   Int                 @default(0)
  createdAt    DateTime            @default(now())

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vendor       Vendor              @relation(fields: [vendorId], references: [id])
  items        PurchaseOrderItem[]

  @@index([tenantId])
  @@index([tenantId, vendorId])
}

model PurchaseOrderItem {
  id        String        @id @default(cuid())
  poId      String
  itemSku   String
  weightMg  Int
  purity    Int
  costPaise Int

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@index([poId])
}

// --------------------------------------------------------------------------
// Sales / POS — core billing
// --------------------------------------------------------------------------

enum PaymentMode {
  CASH
  UPI
  CARD
  CHEQUE
  GOLD_EXCHANGE
  LOYALTY
  STORE_CREDIT
  ADVANCE
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  REFUNDED
}

model Customer {
  id               String    @id @default(cuid())
  tenantId         String
  phone            String
  name             String
  dob              DateTime?
  anniversary      DateTime?
  tags             String[]
  loyaltyPoints    Int       @default(0)
  totalSpendPaise  Int       @default(0)
  storeCreditPaise Int       @default(0)
  lastVisitAt      DateTime?
  createdAt        DateTime  @default(now())

  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bills            Bill[]
  orders           Order[]
  leads            Lead[]
  goldLoans        GoldLoan[]
  estimates        Estimate[]
  repairs          Repair[]
  advances         Advance[]
  cartItems        CartItem[]
  wishlistItems    WishlistItem[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([tenantId, name])
}

model Bill {
  id                  String        @id @default(cuid())
  tenantId            String
  shopId              String
  billNumber          String
  customerId          String?
  // Salesperson on the floor — feeds commission reports. Distinct from
  // createdByUserId (cashier at the till), which we already track.
  salespersonUserId   String?
  registerSessionId   String?
  subtotalPaise       Int
  makingChargesPaise  Int           @default(0)
  stoneChargesPaise   Int           @default(0)
  cgstPaise           Int           @default(0)
  sgstPaise           Int           @default(0)
  igstPaise           Int           @default(0)
  oldGoldValuePaise   Int           @default(0)
  discountPaise       Int           @default(0)
  totalPaise          Int
  paymentStatus       PaymentStatus @default(PENDING)
  idempotencyKey      String
  createdByUserId     String?
  voidedAt            DateTime?
  voidReason          String?
  createdAt           DateTime      @default(now())
  syncedAt            DateTime?

  tenant              Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shop                Shop          @relation(fields: [shopId], references: [id])
  customer            Customer?     @relation(fields: [customerId], references: [id])
  registerSession     RegisterSession? @relation(fields: [registerSessionId], references: [id])
  lines               BillLine[]
  payments            Payment[]
  oldGoldExchange     OldGoldExchange?
  refunds             Refund[]

  @@unique([tenantId, idempotencyKey])
  @@unique([shopId, billNumber])
  @@index([tenantId])
  @@index([tenantId, shopId])
  @@index([tenantId, createdAt])
  @@index([tenantId, customerId])
  @@index([tenantId, salespersonUserId])
  @@index([registerSessionId])
}

model BillLine {
  id                String  @id @default(cuid())
  billId            String
  itemId            String
  weightMg          Int
  purityCaratX100   Int
  ratePerGramPaise  Int
  makingChargeBps   Int     @default(0)
  stoneChargePaise  Int     @default(0)
  linePaise         Int

  bill              Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)
  item              Item    @relation(fields: [itemId], references: [id])

  @@index([billId])
}

model Payment {
  id           String      @id @default(cuid())
  billId       String
  mode         PaymentMode
  amountPaise  Int
  referenceId  String?
  createdAt    DateTime    @default(now())

  bill         Bill        @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
}

model OldGoldExchange {
  id                String @id @default(cuid())
  billId            String @unique
  weightMg          Int
  purityCaratX100   Int
  ratePerGramPaise  Int
  valuePaise        Int

  bill              Bill   @relation(fields: [billId], references: [id], onDelete: Cascade)
}

// Returns / refunds against a posted bill. One bill can have multiple
// partial refunds (e.g. one item returned today, another next week).
model Refund {
  id                String   @id @default(cuid())
  billId            String
  amountPaise       Int
  reason            String
  refundedAt        DateTime @default(now())
  processedByUserId String?

  bill              Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
}

// --------------------------------------------------------------------------
// POS — register sessions (day-open / day-close), parked bills, estimates,
// repairs, advances, cash drawer movements.
// --------------------------------------------------------------------------

enum RegisterSessionStatus {
  OPEN
  CLOSED
}

// One row per "till session" per cashier per shop. Opens when the cashier
// counts the morning float, closes when they reconcile cash at end of day.
// Bills written during the session pin to this row so day-close can compute
// expected cash = opening + cash sales - pay-outs.
model RegisterSession {
  id                  String                @id @default(cuid())
  tenantId            String
  shopId              String
  openedByUserId      String
  openedAt            DateTime              @default(now())
  openingFloatPaise   Int
  closedAt            DateTime?
  closedByUserId      String?
  countedCashPaise    Int?
  expectedCashPaise   Int?
  variancePaise       Int?
  notes               String?
  status              RegisterSessionStatus @default(OPEN)

  tenant              Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shop                Shop         @relation(fields: [shopId], references: [id])
  openedBy            User         @relation(fields: [openedByUserId], references: [id])
  bills               Bill[]
  cashMovements       CashMovement[]

  @@index([tenantId, shopId, status])
  @@index([tenantId, openedAt])
}

enum CashMovementType {
  PAY_IN
  PAY_OUT
  OPENING_FLOAT
  DEPOSIT
}

// Audit trail for non-bill cash drawer activity. Bill cash flows are not
// duplicated here — derive from bills.
model CashMovement {
  id                  String           @id @default(cuid())
  tenantId            String
  shopId              String
  registerSessionId   String?
  type                CashMovementType
  amountPaise         Int
  reason              String
  performedByUserId   String?
  createdAt           DateTime         @default(now())

  tenant              Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shop                Shop             @relation(fields: [shopId], references: [id])
  session             RegisterSession? @relation(fields: [registerSessionId], references: [id])
  performedBy         User?            @relation(fields: [performedByUserId], references: [id])

  @@index([tenantId, shopId, createdAt])
  @@index([registerSessionId])
}

enum ParkedBillStatus {
  ACTIVE
  RESUMED
  ABANDONED
}

// "Park this bill" — customer is browsing more, cashier needs to ring up the
// next person at the counter.
model ParkedBill {
  id                  String           @id @default(cuid())
  tenantId            String
  shopId              String
  parkedByUserId      String
  customerLabel       String           // free-text: customer name or "blue saree lady"
  customerPhone       String?
  draft               Json             // BillCreateSchema-shaped JSON
  status              ParkedBillStatus @default(ACTIVE)
  resumedAt           DateTime?
  abandonedAt         DateTime?
  createdAt           DateTime         @default(now())

  tenant              Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shop                Shop             @relation(fields: [shopId], references: [id])
  parkedBy            User             @relation(fields: [parkedByUserId], references: [id])

  @@index([tenantId, shopId, status])
  @@index([tenantId, createdAt])
}

enum EstimateStatus {
  DRAFT
  SENT
  CONVERTED
  EXPIRED
}

// Kachi parchi — the "thinking about it" rough quote that gold shop owners
// hand to customers before they commit. Convert to a Bill when accepted.
model Estimate {
  id                  String           @id @default(cuid())
  tenantId            String
  shopId              String
  estimateNumber      String
  customerId          String?
  customerLabel       String
  customerPhone       String?
  createdByUserId     String
  // Frozen rate per purity at time of quote (denormalized JSON: { "2200": 642000 }).
  // Gold rates fluctuate — the kachi parchi guarantees the quoted rate for
  // the validity window.
  ratesSnapshotJson   Json
  lines               Json             // BillLineInput[] structure
  subtotalPaise       Int
  makingChargesPaise  Int
  totalPaise          Int
  validUntil          DateTime
  convertedBillId     String?
  status              EstimateStatus   @default(DRAFT)
  createdAt           DateTime         @default(now())

  tenant              Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shop                Shop             @relation(fields: [shopId], references: [id])
  customer            Customer?        @relation(fields: [customerId], references: [id])
  createdBy           User             @relation(fields: [createdByUserId], references: [id])

  @@unique([shopId, estimateNumber])
  @@index([tenantId, shopId])
  @@index([tenantId, customerId])
  @@index([tenantId, status])
}

enum RepairStatus {
  INTAKE
  IN_WORKSHOP
  READY
  DELIVERED
  CANCELLED
}

// Repair / job-work intake: customer drops off a piece for re-polish,
// re-sizing, soldering. Tracks weight in/out, problem, ETA, advance taken.
model Repair {
  id                  String       @id @default(cuid())
  tenantId            String
  shopId              String
  ticketNumber        String
  customerId          String?
  customerName        String
  customerPhone       String
  itemDescription     String
  weightInMg          Int
  weightOutMg         Int?
  purityCaratX100     Int
  problem             String
  estimatedCostPaise  Int
  finalCostPaise      Int?
  advancePaise        Int          @default(0)
  intakeUserId        String
  promisedAt          DateTime?
  status              RepairStatus @default(INTAKE)
  notes               String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  tenant              Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shop                Shop         @relation(fields: [shopId], references: [id])
  customer            Customer?    @relation(fields: [customerId], references: [id])
  intakeUser          User         @relation("RepairIntakeBy", fields: [intakeUserId], references: [id])

  @@unique([shopId, ticketNumber])
  @@index([tenantId, status])
  @@index([tenantId, customerPhone])
}

enum AdvanceStatus {
  ACTIVE
  CONSUMED
  REFUNDED
}

// Advance / booking receipt: customer pays ₹50,000 to lock today's gold
// rate against a future bridal-set order. Consumed when the final bill is
// generated (consumedBillId).
model Advance {
  id                  String        @id @default(cuid())
  tenantId            String
  shopId              String
  receiptNumber       String
  customerId          String
  amountPaise         Int
  lockedRatesJson     Json?
  notes               String?
  validUntil          DateTime?
  status              AdvanceStatus @default(ACTIVE)
  consumedBillId      String?
  refundedAt          DateTime?
  createdByUserId     String
  createdAt           DateTime      @default(now())

  tenant              Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shop                Shop          @relation(fields: [shopId], references: [id])
  customer            Customer      @relation(fields: [customerId], references: [id])
  createdBy           User          @relation(fields: [createdByUserId], references: [id])

  @@unique([shopId, receiptNumber])
  @@index([tenantId, customerId])
  @@index([tenantId, status])
}

// --------------------------------------------------------------------------
// Finance
// --------------------------------------------------------------------------

enum GoldLoanStatus {
  ACTIVE
  PARTIALLY_REPAID
  CLOSED
  DEFAULTED
}

// Capital expenses (machinery, furniture, vehicles) are amortised; revenue
// expenses (rent, electricity, vendor bills) hit P&L immediately. CA-friendly
// classification surfaced in the Finance UI and Tally export.
enum ExpenseClassification {
  REVENUE
  CAPITAL
}

model Expense {
  id                   String                @id @default(cuid())
  tenantId             String
  shopId               String
  category             String
  amountPaise          Int
  paidAt               DateTime
  notes                String?
  receiptUrl           String?
  classification       ExpenseClassification @default(REVENUE)
  isRecurring          Boolean               @default(false)
  recurringIntervalDays Int?
  paymentMode          PaymentMode?
  vendorId             String?
  bankAccountId        String?
  createdAt            DateTime              @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shop        Shop     @relation(fields: [shopId], references: [id])
  vendor      Vendor?  @relation(fields: [vendorId], references: [id])
  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id])

  @@index([tenantId])
  @@index([tenantId, shopId, paidAt])
  @@index([tenantId, classification, paidAt])
  @@index([tenantId, vendorId])
}

model GoldLoan {
  id               String         @id @default(cuid())
  tenantId         String
  customerId       String
  principalPaise   Int
  interestRateBps  Int
  pledgedWeightMg  Int
  status           GoldLoanStatus @default(ACTIVE)
  dueAt            DateTime

  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer         Customer       @relation(fields: [customerId], references: [id])
  repayments       GoldLoanRepayment[]

  @@index([tenantId])
  @@index([tenantId, customerId])
}

model GoldLoanRepayment {
  id          String   @id @default(cuid())
  loanId      String
  amountPaise Int
  paidAt      DateTime

  loan        GoldLoan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
}

model Payroll {
  id              String   @id @default(cuid())
  tenantId        String
  userId          String
  month           String   // "YYYY-MM"
  basePaise       Int
  commissionPaise Int      @default(0)
  advancePaise    Int      @default(0)
  netPaise        Int
  paidAt          DateTime?

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, month])
  @@index([tenantId])
}

// --------------------------------------------------------------------------
// CRM
// --------------------------------------------------------------------------

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  NEGOTIATION
  CONVERTED
  LOST
}

enum WhatsAppMessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

model Lead {
  id                String     @id @default(cuid())
  tenantId          String
  source            String
  customerId        String?
  name              String
  phone             String
  interest          String?
  status            LeadStatus @default(NEW)
  assignedToUserId  String?
  utmSource         String?
  utmCampaign       String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  tenant            Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer          Customer?  @relation(fields: [customerId], references: [id])
  activities        LeadActivity[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model LeadActivity {
  id                String   @id @default(cuid())
  leadId            String
  type              String
  notes             String?
  performedByUserId String?
  createdAt         DateTime @default(now())

  lead              Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model WhatsAppMessage {
  id            String                @id @default(cuid())
  tenantId      String
  leadId        String?
  customerId    String?
  templateName  String
  body          String
  status        WhatsAppMessageStatus @default(QUEUED)
  sentAt        DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime              @default(now())

  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
}

// --------------------------------------------------------------------------
// E-Commerce
// --------------------------------------------------------------------------

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

model Product {
  id                 String   @id @default(cuid())
  tenantId           String
  name               String
  slug               String
  categoryId         String
  descriptionMd      String
  images             String[]
  weightMg           Int
  purityCaratX100    Int
  makingChargeBps    Int
  basePricePaise     Int
  stoneChargePaise   Int      @default(0)
  isPublished        Boolean  @default(false)
  createdAt          DateTime @default(now())

  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category           Category @relation(fields: [categoryId], references: [id])
  orderItems         OrderItem[]
  cartItems          CartItem[]
  wishlistItems      WishlistItem[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, isPublished])
}

model Order {
  id              String      @id @default(cuid())
  tenantId        String
  customerId      String
  status          OrderStatus @default(PENDING)
  subtotalPaise   Int
  shippingPaise   Int         @default(0)
  taxPaise        Int         @default(0)
  totalPaise      Int
  paymentMethod   String
  razorpayOrderId String?
  shiprocketAwb   String?
  expectedDeliveryAt DateTime?
  // Free-form reason captured when the order moves to CANCELLED or RETURNED.
  // Surfaced verbatim on the customer track page so the customer sees the
  // same explanation the cashier wrote.
  cancelReason    String?
  createdAt       DateTime    @default(now())

  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer        Customer    @relation(fields: [customerId], references: [id])
  items           OrderItem[]
  events          OrderEvent[]

  @@index([tenantId])
  @@index([tenantId, status])
  // Orders list endpoint (/ecommerce/orders) is the heaviest read on the
  // admin side — it polls every 10s and orders by createdAt DESC. A
  // descending (tenantId, createdAt) index lets Postgres serve that page
  // with an index-only scan instead of a sort.
  @@index([tenantId, createdAt(sort: Desc)])
  // Reservations filter (paymentMethod = 'reserve-at-store') hits this
  // table on every poll of the live-count endpoint.
  @@index([tenantId, paymentMethod])
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  productId  String
  qty        Int     @default(1)
  pricePaise Int

  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

// Persistent storefront customer cart. One row per (customer, product) pair
// — qty bumps are an upsert. Replaces the localStorage-only cart in
// `shopSlice.ts` so a customer can add a piece on mobile and check out on
// desktop. Anonymous shoppers still use localStorage; on sign-in we sync
// the local cart into here via `POST /website/cart/items` (merge-by-product).
model CartItem {
  id         String   @id @default(cuid())
  tenantId   String
  customerId String
  productId  String
  qty        Int      @default(1)
  addedAt    DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@index([tenantId, customerId])
}

// Persistent storefront customer wishlist. Same shape as CartItem minus qty
// (a wishlist entry is binary — the piece is favorited or it isn't).
model WishlistItem {
  id         String   @id @default(cuid())
  tenantId   String
  customerId String
  productId  String
  addedAt    DateTime @default(now())

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@index([tenantId, customerId])
}

// Append-only timeline of state transitions on an Order. One row per status
// change (plus the initial PENDING placement). Drives the live customer
// tracking page and the admin order drawer's "what happened when" timeline.
//
// `actorName` is a free-form label ("System", "Priya at Store", "Shiprocket
// courier") rather than a hard FK so unauthenticated public-side events and
// third-party webhook events can co-exist with admin-authored ones.
//
// `location` is the optional "where is the piece right now" string surfaced
// to the customer ("Mumbai sort hub", "Out for delivery, Gurgaon").
model OrderEvent {
  id         String      @id @default(cuid())
  orderId    String
  tenantId   String
  status     OrderStatus
  note       String?
  location   String?
  actorName  String?
  createdAt  DateTime    @default(now())

  order      Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@index([tenantId, createdAt])
}

// --------------------------------------------------------------------------
// Storefront content (CMS-driven public website)
// --------------------------------------------------------------------------

model StorefrontContent {
  tenantId  String   @id
  content   Json
  version   Int      @default(1)
  updatedAt DateTime @updatedAt
  updatedBy String?

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// --------------------------------------------------------------------------
// Audit
// --------------------------------------------------------------------------

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String?
  entityType  String
  entityId    String
  action      String
  beforeJson  Json?
  afterJson   Json?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
  @@index([tenantId, userId, createdAt])
}

// --------------------------------------------------------------------------
// Daily gold/silver rate snapshot. Global (not tenant-scoped) — Indian retail
// gold rate is a national benchmark. One row per IST calendar day; the worker
// checks for today's row before calling GoldAPI.io so restarts and redeploys
// cannot trigger duplicate fetches. Daily call budget stays at ~30/month.
// --------------------------------------------------------------------------

model GoldRateDaily {
  date         DateTime @id @db.Date
  fetchedAt    DateTime @default(now())
  source       String   @default("goldapi.io")
  premiumBps   Int
  rate24KPaise Int
  rate22KPaise Int
  rate18KPaise Int
  rate14KPaise Int
  silverPaise  Int

  @@index([fetchedAt])
}

// --------------------------------------------------------------------------
// Finance — Banking & Reconciliation
// --------------------------------------------------------------------------

enum BankAccountType {
  CURRENT
  SAVINGS
  OD
  CC
  OTHER
}

enum BankTxnDirection {
  CREDIT
  DEBIT
}

// One row per bank account the business operates. Future-ready for actual
// API integrations (Razorpay X, Decentro, plaid-style aggregators); for v1
// the bookkeeping is manual but the schema is shaped to absorb a sync feed.
model BankAccount {
  id               String          @id @default(cuid())
  tenantId         String
  nickname         String          // "HDFC current — Gurugram main"
  bankName         String
  accountLast4     String          // never store full account number
  ifsc             String?
  type             BankAccountType @default(CURRENT)
  openingBalancePaise Int          @default(0)
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())

  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions     BankTransaction[]
  vendorPayments   VendorPayment[]
  expenses         Expense[]

  @@index([tenantId, isActive])
}

model BankTransaction {
  id            String           @id @default(cuid())
  tenantId      String
  accountId     String
  direction     BankTxnDirection
  amountPaise   Int
  balancePaise  Int?             // running balance after this txn, if known
  description   String
  referenceId   String?
  occurredAt    DateTime
  // Optional links so a bank credit can be tied back to a bill/expense for
  // recon. None of these are required — manual entries leave them null.
  billId        String?
  expenseId     String?
  vendorPaymentId String?
  reconciledAt  DateTime?
  createdAt     DateTime         @default(now())

  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account       BankAccount      @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([tenantId, accountId, occurredAt])
  @@index([tenantId, reconciledAt])
}

// One row per shop per day per cashier — close-of-day reconciliation log.
// Expected vs counted for cash, UPI, card. Variance > 0 = excess, < 0 = short.
model Reconciliation {
  id                    String   @id @default(cuid())
  tenantId              String
  shopId                String
  reconciledDate        DateTime @db.Date
  expectedCashPaise     Int      @default(0)
  countedCashPaise      Int      @default(0)
  expectedUpiPaise      Int      @default(0)
  settledUpiPaise       Int      @default(0)
  expectedCardPaise     Int      @default(0)
  settledCardPaise      Int      @default(0)
  varianceCashPaise     Int      @default(0)
  varianceUpiPaise      Int      @default(0)
  varianceCardPaise     Int      @default(0)
  notes                 String?
  reconciledByUserId    String?
  createdAt             DateTime @default(now())

  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, shopId, reconciledDate])
  @@index([tenantId, reconciledDate])
}
