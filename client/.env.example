# Vite reads VITE_*. All app config flows via the server's /api, so this file is intentionally sparse.
VITE_APP_NAME=Zelora
VITE_ADMIN_EMAIL=admin@zelora.in
VITE_ADMIN_PASSWORD=zelora123
# Bearer token the admin session sends to the API. Must match the server's
# ADMIN_API_TOKEN. Use a long random string in production.
VITE_ADMIN_API_TOKEN=admin-session-token

# Cloudinary unsigned upload — used by POS quick-add, product images,
# customer photos, etc. Both vars are REQUIRED for image upload to work;
# without them the image upload UI shows a clear "not configured" message.
#
# Setup (one-time):
#   1. Sign up at cloudinary.com → grab the cloud name from the dashboard.
#   2. Settings → Upload → Add upload preset.
#        - Signing mode: Unsigned
#        - Folder: zelora/products (recommended)
#        - Allowed formats: jpg, jpeg, png, webp
#        - Transformations: w_1200,c_limit,q_auto,f_auto
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
