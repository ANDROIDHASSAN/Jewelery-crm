# Vite reads VITE_*. All app config flows via the server's /api, so this file is intentionally sparse.
VITE_APP_NAME=Zelora
VITE_ADMIN_EMAIL=admin@zelora.in
VITE_ADMIN_PASSWORD=zelora123
# Bearer token the admin session sends to the API. Must match the server's
# ADMIN_API_TOKEN. Use a long random string in production.
VITE_ADMIN_API_TOKEN=admin-session-token

# Cloudinary image upload — preferred path is to set CLOUDINARY_URL on the
# SERVER (server/.env). When the server has it, the client fetches a signed
# upload payload from /api/v1/uploads/cloudinary-sign and posts the file
# directly to Cloudinary. No client config needed.
#
# The two VITE_ vars below are only needed as a fallback when the server
# isn't configured (e.g. public storefront uploads with no auth header).
# To use them: create an unsigned upload preset in the Cloudinary dashboard
# (Settings → Upload → Add upload preset → Signing mode: Unsigned).
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
