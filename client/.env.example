# Vite reads VITE_*. All app config flows via the server's /api, so this file is intentionally sparse.
VITE_APP_NAME=Zelora
VITE_ADMIN_EMAIL=admin@zelora.in
VITE_ADMIN_PASSWORD=zelora123
# Bearer token the admin session sends to the API. Must match the server's
# ADMIN_API_TOKEN. Use a long random string in production.
VITE_ADMIN_API_TOKEN=admin-session-token
